RewriteEngine On
RewriteRule ^$ php/index.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ php/$1 [L]

# Fix Models & JSON loading on strict/free hosting environments
<IfModule mod_mime.c>
    AddType application/json .json
    AddType application/octet-stream .bin .data
</IfModule>

<FilesMatch "^[^.]+$">
    ForceType application/octet-stream
    Header set Access-Control-Allow-Origin "*"
</FilesMatch>

<FilesMatch "\.(json|bin)$">
    Header set Access-Control-Allow-Origin "*"
</FilesMatch>
